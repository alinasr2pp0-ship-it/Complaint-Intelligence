modules = ["python-3.12", "nodejs-20", "web"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt"]

[agent]
expertMode = true

[userenv]

[userenv.shared]
CORS_ORIGINS = "*"
EMBEDDING_DIMENSION = "1024"
EMBEDDING_MODEL = "voyage-3"
LOG_LEVEL = "INFO"
PINECONE_CLOUD = "aws"
PINECONE_INDEX_NAME = "complaints-rag"
PINECONE_METRIC = "cosine"
PINECONE_NAMESPACE = "default"
PINECONE_REGION = "us-east-1"
RETRIEVER_SEARCH_TYPE = "similarity"
RETRIEVER_TOP_K = "3"
VOYAGE_BATCH_SIZE = "128"
OPENROUTER_FALLBACK_MODELS = "mistralai/mistral-small-2506,deepseek/deepseek-chat,google/gemma-3-4b-it:free"
OPENROUTER_PRIMARY_MODEL = "meta-llama/llama-3.2-3b-instruct:free"

[userenv.production]
ENVIRONMENT = "production"

[userenv.development]
ENVIRONMENT = "development"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5173

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && gunicorn --bind=0.0.0.0:8000 --workers=2 app.main:app -k uvicorn.workers.UvicornWorker"]
build = ["bash", "-c", "cd frontend && npm install && npm run build"]
